{
  "name": "bpm-counter",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@microsoft/applicationinsights-clickanalytics-js": "^3.4.1",
    "@microsoft/applicationinsights-react-js": "^19.3.8",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "audiomotion-analyzer": "^3.5.0",
    "bpm-detective": "^2.0.5",
    "loglevel": "^1.7.1",
    "react": "^19.0.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.0.0",
    "react-ga4": "^1.1.2",
    "react-router-dom": "^7.14.0",
    "react-scripts": "^5.0.1",
    "react-toastify": "^11.0.0",
    "react-tooltip": "^5.30.0",
    "realtime-bpm-analyzer": "^5.0.2",
    "web-vitals": "^5.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && npm run build-sw",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "startsecure": "cross-env HTTPS=true SSL_CRT_FILE=192.168.1.9.pem SSL_KEY_FILE=192.168.1.9-key.pem react-scripts start",
    "startprod": "cross-env NODE_ENV=production react-scripts start",
    "build-sw": "node sw-build.js && npx rollup -c",
    "generate-test-audio": "node scripts/generate-test-audio.js",
    "test:e2e": "npx playwright test",
    "test:e2e:bpm": "npx playwright test --project=bpm-detection",
    "fix-ssl": "npm audit fix --force"
  },
  "jest": {
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.0.0",
    "cross-env": "^7.0.3",
    "rollup": "^2.56.3",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-replace": "^2.2.0",
    "rollup-plugin-terser": "^7.0.2",
    "workbox-build": "^7.0.0"
  }
}
